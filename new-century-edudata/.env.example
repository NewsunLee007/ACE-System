# 数据库配置
# 生产部署到 Vercel + Neon 时，使用 Neon 提供的 Postgres 连接串:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#
# 本地或 Docker Compose 可继续使用 MariaDB / MySQL-compatible
# Docker Compose 内部连接使用 db:3306
DATABASE_URL=mysql+pymysql://root:NewCentury2025!@db:3306/new_century_edudata?charset=utf8mb4
# 本机直连本地 MariaDB 时使用 localhost:3306
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/new_century_edudata?charset=utf8mb4

# 应用配置
APP_NAME=新纪元教务大数据平台
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=info

# 前端配置
# Vercel 生产环境默认走同域 API: /api/v1
# 本地容器/Nginx 生产环境也可反代到 /api/v1
# 本地开发如需直连后端，可在 frontend/.env.local 中配置:
# REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/tmp/uploads

# 邮件配置(可选)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Redis配置(可选，用于缓存)
REDIS_URL=redis://localhost:6379/0

# AI分析配置(可选)
# DeepSeek key 只放在后端环境变量，不能写入前端或提交真实密钥
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
