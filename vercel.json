{
  "version": 2,
  "installCommand": "cd new-century-edudata/frontend && npm ci",
  "buildCommand": "cd new-century-edudata/frontend && npm run build",
  "outputDirectory": "new-century-edudata/frontend/build",
  "functions": {
    "api/index.py": {
      "includeFiles": "new-century-edudata/{backend,database,scripts,frontend/src/data}/**"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/ready",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/redoc",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
